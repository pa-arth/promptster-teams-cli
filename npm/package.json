{
  "name": "@promptster/teams-cli",
  "version": "0.11.1",
  "description": "On-device, auditable AI-coding capture for internal engineering teams",
  "keywords": [
    "promptster",
    "cli",
    "teams",
    "ai",
    "observability",
    "developer-productivity"
  ],
  "homepage": "https://github.com/pa-arth/promptster-teams-cli",
  "repository": {
    "type": "git",
    "url": "https://github.com/pa-arth/promptster-teams-cli"
  },
  "license": "MIT",
  "bin": {
    "promptster-teams": "./bin/promptster-teams.js"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "postinstall": "node scripts/postinstall.js",
    "prepublishOnly": "node scripts/build.js && node scripts/check-binaries.js"
  },
  "files": [
    "bin/",
    "lib/",
    "scripts/postinstall.js",
    "README.md"
  ],
  "engines": {
    "node": ">=16"
  },
  "publishConfig": {
    "access": "public"
  },
  "optionalDependencies": {
    "@promptster/teams-cli-linux-x64": "0.11.1",
    "@promptster/teams-cli-linux-arm64": "0.11.1",
    "@promptster/teams-cli-darwin-x64": "0.11.1",
    "@promptster/teams-cli-darwin-arm64": "0.11.1",
    "@promptster/teams-cli-win32-x64": "0.11.1",
    "@promptster/teams-cli-win32-arm64": "0.11.1"
  }
}
